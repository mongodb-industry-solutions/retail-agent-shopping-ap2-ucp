# Card Payment Flow - Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Google Authentication ====================
# Option A: Google API Key (recommended for development)
GOOGLE_API_KEY=

# Option B: Vertex AI (recommended for production)
# Uncomment these and comment out GOOGLE_API_KEY above
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ==================== Mandate Ledger Service ====================
# URL where the ledger service is running
MANDATE_LEDGER_SERVICE_URL=http://localhost:5000

# Merchant Agent API key from bootstrap setup
# Run: PYTHONPATH=. python3 scripts/setup_agent_keys.py
MANDATE_LEDGER_API_KEY=mlsk_your_merchant_agent_key_here
