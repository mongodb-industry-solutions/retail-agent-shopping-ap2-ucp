# Mandate Ledger Service - Environment Configuration
# Copy this file to .env and fill in your values

# ==================== MongoDB Configuration ====================
# MongoDB Atlas connection string or local MongoDB URI
MONGODB_URI=

# Database name
MONGODB_DATABASE=mandate_ledger

# ==================== Service Configuration ====================
SERVICE_NAME=mandate-ledger-service
ENVIRONMENT=development
LOG_LEVEL=INFO

# ==================== Bootstrap Authentication ====================
# Used for initial API key setup only. Disable after creating keys!
# Generate secure key: openssl rand -hex 32
BOOTSTRAP_ADMIN_KEY=your_secure_bootstrap_key_here
ENABLE_BOOTSTRAP_AUTH=true

# ==================== Security ====================
# Comma-separated list of allowed origins, or * for all
ALLOWED_CORS_ORIGINS=*

# API rate limiting (requests per minute per agent)
DEFAULT_RATE_LIMIT_PER_MINUTE=60

# API key hashing algorithm
API_KEY_HASH_ALGORITHM=bcrypt
